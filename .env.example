# RoomFindR Environment Variables (Supabase)

## Supabase Configuration
# Get these from your Supabase project dashboard: https://app.supabase.com
VITE_SUPABASE_URL=your_supabase_project_url
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key

## Application Settings
VITE_BACKEND_MODE=supabase
VITE_PAYMENT_PROVIDER=cashfree
VITE_CASHFREE_ENV=test

# Cashfree payout 2FA stays server-side. Keep these in backend env/secrets, not VITE_* vars.
CASHFREE_ENV=test
CASHFREE_PAYOUT_ENV=test
CASHFREE_PAYOUT_CLIENT_ID=your_cashfree_payout_client_id
CASHFREE_PAYOUT_CLIENT_SECRET=your_cashfree_payout_client_secret
CASHFREE_PAYOUT_PUBLIC_KEY_PEM=your_cashfree_payout_public_key_pem
CASHFREE_PAYOUT_WEBHOOK_SECRET=your_cashfree_payout_webhook_secret

# Resend SMTP (Supabase Auth Email OTP)
RESEND_SMTP_USER=resend
RESEND_SMTP_PASS=your_resend_api_key
RESEND_FROM_EMAIL=onboarding@yourdomain.com

# Admin bootstrap email (optional)
VITE_ADMIN_BOOTSTRAP_EMAIL=admin@yourdomain.com

# Payment URLs
VITE_PAYMENT_RETURN_URL=/payment/confirmed
VITE_APP_DEEP_LINK_SCHEME=roomfindr://

# Optional production cache and monitoring
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
CACHE_DEBUG=false
SENTRY_DSN=
SENTRY_ENVIRONMENT=production
VITE_SENTRY_DSN=
VITE_SENTRY_ENVIRONMENT=production
VITE_SENTRY_RELEASE=
VITE_SENTRY_TRACES_SAMPLE_RATE=0.1
