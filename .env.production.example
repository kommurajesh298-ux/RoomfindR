# Frontend build-time variables
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
VITE_PAYMENT_PROVIDER=cashfree
VITE_CASHFREE_ENV=production
VITE_PAYMENT_RETURN_BASE_URL=
VITE_ADMIN_BOOTSTRAP_EMAIL=

# Frontend monitoring
VITE_SENTRY_DSN=
VITE_SENTRY_ENVIRONMENT=production
VITE_SENTRY_RELEASE=
VITE_SENTRY_TRACES_SAMPLE_RATE=0.1

# Container runtime
NODE_ENV=production

# Supabase Edge Function secrets
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
CACHE_DEBUG=false
SENTRY_DSN=
SENTRY_ENVIRONMENT=production

# Cashfree server-side secrets
CASHFREE_ENV=production
CASHFREE_PAYOUT_ENV=production
CASHFREE_PAYOUT_CLIENT_ID=
CASHFREE_PAYOUT_CLIENT_SECRET=
CASHFREE_PAYOUT_PUBLIC_KEY_PEM=
CASHFREE_PAYOUT_WEBHOOK_SECRET=
