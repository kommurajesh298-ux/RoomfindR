# Cashfree PG Credentials
CASHFREE_CLIENT_ID=your_cashfree_client_id
CASHFREE_CLIENT_SECRET=your_cashfree_client_secret
CASHFREE_API_VERSION=2025-01-01
CASHFREE_ENV=test

# Cashfree Payouts Credentials (required for owner bank verification + payout webhook)
CASHFREE_PAYOUT_CLIENT_ID=your_cashfree_payout_client_id
CASHFREE_PAYOUT_CLIENT_SECRET=your_cashfree_payout_client_secret
CASHFREE_PAYOUT_PUBLIC_KEY=your_cashfree_payout_public_key_pem
CASHFREE_PAYOUT_PUBLIC_KEY_PEM=your_cashfree_payout_public_key_pem
CASHFREE_PAYOUT_WEBHOOK_SECRET=your_cashfree_payout_webhook_secret
CASHFREE_PAYOUT_API_VERSION=2024-01-01
CASHFREE_PAYOUT_ENV=test

# Return + webhook handling
CASHFREE_WEBHOOK_URL=https://your-project-ref.supabase.co/functions/v1/verifyCashfreeWebhook
PAYMENT_RETURN_BASE_URL=https://your-public-app-domain.com
ALLOWED_ORIGINS=https://your-project-ref.supabase.co,https://localhost,http://localhost,capacitor://localhost,http://localhost:5173,http://localhost:5174,http://localhost:5175,http://127.0.0.1:5173,http://127.0.0.1:5174,http://127.0.0.1:5175
# Payment return URL should point to a public frontend URL or app scheme, never localhost/private LAN IPs.

# Supabase Credentials (Required for Edge Functions)
SUPABASE_URL=your_supabase_url
SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# Firebase Cloud Messaging
FCM_SERVER_KEY=your_fcm_server_key
